<clickhouse>
  <storage_configuration>
    <disks>
      <minio_bronze>
        <type>s3</type>
        <endpoint from_env="MINIO_BRONZE_ENDPOINT"/>
        <access_key_id from_env="MINIO_ACCESS_KEY"/>
        <secret_access_key from_env="MINIO_SECRET_KEY"/>
        <force_path_style>1</force_path_style>
        <signature_version>4</signature_version>
        <!-- Add these parameters to prevent blocking  -->
        <connect_timeout_ms>5000</connect_timeout_ms>
        <request_timeout_ms>5000</request_timeout_ms>
        <max_connections>10</max_connections>
        <retry_attempts>3</retry_attempts>
        <skip_access_check>1</skip_access_check>
      </minio_bronze>
      <minio_silver>
        <type>s3</type>
        <endpoint from_env="MINIO_SILVER_ENDPOINT"/>
        <access_key_id from_env="MINIO_ACCESS_KEY"/>
        <secret_access_key from_env="MINIO_SECRET_KEY"/>
        <force_path_style>1</force_path_style>
        <signature_version>4</signature_version>
        <!-- Add these parameters to prevent blocking  -->
        <connect_timeout_ms>5000</connect_timeout_ms>
        <request_timeout_ms>5000</request_timeout_ms>
        <max_connections>10</max_connections>
        <retry_attempts>3</retry_attempts>
        <skip_access_check>1</skip_access_check>
      </minio_silver>
      <minio_gz_loop>
        <type>s3</type>
        <endpoint from_env="MINIO_GZ_LOOP_ENDPOINT"/>
        <access_key_id from_env="MINIO_ACCESS_KEY"/>
        <secret_access_key from_env="MINIO_SECRET_KEY"/>
        <force_path_style>1</force_path_style>
        <signature_version>4</signature_version>
        <!-- Add these parameters to prevent blocking  -->
        <connect_timeout_ms>5000</connect_timeout_ms>
        <request_timeout_ms>5000</request_timeout_ms>
        <max_connections>10</max_connections>
        <retry_attempts>3</retry_attempts>
        <skip_access_check>1</skip_access_check>
      </minio_gz_loop>
    </disks>
    <policies>
        <bronze_policy>
            <volumes>
                <bronze>
                    <disk>minio_bronze</disk>
                </bronze>
            </volumes>
        </bronze_policy>

        <silver_policy>
            <volumes>
                <silver>
                    <disk>minio_silver</disk>
                </silver>
            </volumes>
        </silver_policy>

        <gz_loop_policy>
            <volumes>
                <gz_loop>
                    <disk>minio_gz_loop</disk>
                </gz_loop>
            </volumes>
        </gz_loop_policy>
    </policies>
  </storage_configuration>
  
  <!-- Ensure ClickHouse listens on all interfaces -->
  <listen_host>0.0.0.0</listen_host>
</clickhouse>