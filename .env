ENV=local
MINIO_BASE_URL=http://minio:9000
MINIO_BUCKET=clickhouse-${ENV}
MINIO_BRONZE_ENDPOINT=${MINIO_BASE_URL}/${MINIO_BUCKET}/bronze/
MINIO_SILVER_ENDPOINT=${MINIO_BASE_URL}/${MINIO_BUCKET}/silver/
MINIO_GZ_LOOP_ENDPOINT=${MINIO_BASE_URL}/${MINIO_BUCKET}/gz_loop/
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123

# Airflow UID (default: 50000)
AIRFLOW_IMAGE_NAME=apache/airflow:3.0.6
AIRFLOW_UID=50000
