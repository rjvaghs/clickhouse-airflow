INSERT INTO {{ target_db }}.{{ target_table }}
(
    log_date,
    region,
    state,
    city,
    fc_code,
    fc_name,
    resource_type,
    job_type,
    budgeted,
    over_budget,
    active,
    present,
    utilized,
    absent_rate,
    shortage_rate,
    productivity_actual,
    productivity_goal
)
WITH
{% if log_dates is defined and log_dates %}
log_dates_filter AS (
    SELECT toDate(d) AS log_date
    FROM (
        SELECT arrayJoin([
            {% for d in log_dates %}
            '{{ d }}'{% if not loop.last %}, {% endif %}
            {% endfor %}
        ]) AS d
    )
),
log_months_filter AS (
    SELECT DISTINCT toStartOfMonth(log_date) AS month_year
    FROM log_dates_filter
),
{% endif %}
fc_productivity AS (
    SELECT
        log_date,
        fc_code,
        fc_name,
        argMax(delivered_shipments_volume, created_ts) AS delivered_shipments_volume,
        argMax(hd_delivered_shipments_volume, created_ts) AS hd_delivered_shipments_volume,
        argMax(pup_delivered_shipments_volume, created_ts) AS pup_delivered_shipments_volume,
        argMax(hd_consumed_capacity, created_ts) AS hd_consumed_capacity,
        argMax(pup_consumed_capacity, created_ts) AS pup_consumed_capacity,
        argMax(hd_set_capacity, created_ts) AS hd_set_capacity,
        argMax(pup_set_capacity, created_ts) AS pup_set_capacity,
        argMax(hd_on_time_delivered_shipments, created_ts) AS hd_on_time_delivered_shipments,
        argMax(pup_on_time, created_ts) AS pup_on_time,
        argMax(total_hd_orders_count, created_ts) AS total_hd_orders_count,
        argMax(total_pup_orders_count, created_ts) AS total_pup_orders_count,
        argMax(hd_adj_ds, created_ts) AS hd_adj_ds
    FROM
        {{ source_db }}.{{ source_table_fc_productivity }}
    {% if log_dates is defined and log_dates %}
    WHERE log_date IN (SELECT log_date FROM log_dates_filter)
    {% endif %}
    GROUP BY
        log_date, fc_code, fc_name
),
latest_attendance AS (
    SELECT
        employee_id,
        log_date,
        argMax(fc_code, created_ts) AS fc_code,
        argMax(job_type, created_ts) AS job_type,
        argMax(role, created_ts) AS role,
        argMax(is_active, created_ts) AS is_active,
        argMax(is_present, created_ts) AS is_present,
        argMax(on_leave, created_ts) AS on_leave
    FROM
        {{ source_db }}.{{ source_table_employee_daily_attendance }}
    {% if log_dates is defined and log_dates %}
    WHERE log_date IN (SELECT log_date FROM log_dates_filter)
    {% endif %}
    GROUP BY
        employee_id, log_date
),
attendance AS (
    SELECT 
        log_date,
        fc_code,
        CASE WHEN job_type = 'DCD' THEN 'DCD'
             WHEN job_type = 'VEHICLES' THEN 'VEHICLES'
             WHEN job_type = 'FT' THEN 'FULL_TIME'
             WHEN job_type = 'PT' THEN 'PART_TIME'
             ELSE NULL END AS job_type,
        role,
        toInt32(countIf(is_active = 1)) AS active,
        toInt32(countIf(is_present = 1)) AS present,
        toInt32(countIf(on_leave = 1)) AS on_leave,
        (1-(present/active))*100 AS absent_rate
    FROM
        latest_attendance
    GROUP BY
        log_date, fc_code, job_type, role
),
da_productivity AS (
    SELECT
        log_date,
        fc_code,
        fc_name,
        toInt32(argMax(distinct_full_time_das, created_ts)) AS distinct_full_time_das,
        toInt32(argMax(distinct_part_time_das, created_ts)) AS distinct_part_time_das,
        toInt32(argMax(distinct_dcd, created_ts)) AS distinct_dcd,
        toInt32(argMax(distinct_dpd, created_ts)) AS distinct_dpd,
        toInt32(argMax(hd_dcd_delivered_orders_count, created_ts)) AS hd_dcd_delivered_orders_count,
        toInt32(argMax(hd_dpd_delivered_orders_count, created_ts)) AS hd_dpd_delivered_orders_count,
        toInt32(argMax(hd_full_time_delivered_orders_count, created_ts)) AS hd_full_time_delivered_orders_count,
		toInt32(argMax(hd_part_time_delivered_orders_count, created_ts)) AS hd_part_time_delivered_orders_count
    FROM 
        {{ source_db }}.{{ source_table_da_productivity }}
    {% if log_dates is defined and log_dates %}
    WHERE log_date IN (SELECT log_date FROM log_dates_filter)
    {% endif %}
    GROUP BY
        log_date, fc_code, fc_name
),
shopper_productivity AS (
    SELECT
        log_date,
        fc_code,
        fc_name,
        toInt32(argMax(distinct_full_time_shoppers, created_ts)) AS distinct_full_time_shoppers,
        toInt32(argMax(distinct_part_time_shoppers, created_ts)) AS distinct_part_time_shoppers,
        toInt32(argMax(items_packed_count_full_time, created_ts)) AS items_packed_count_full_time,
        toInt32(argMax(items_packed_count_part_time, created_ts)) AS items_packed_count_part_time
    FROM
        {{ source_db }}.{{ source_table_shopper_productivity }}
    {% if log_dates is defined and log_dates %}
    WHERE log_date IN (SELECT log_date FROM log_dates_filter)
    {% endif %}
    GROUP BY
        log_date, fc_code, fc_name
),
latest_vehicle_productivity AS (
    SELECT
        log_date,
        fc_code,
        fc_name,
        toInt32(argMax(no_of_vehicles, created_ts)) AS no_of_vehicles,
        toInt32(argMax(vehicle_checkin_count, created_ts)) AS vehicle_checkin_count,
        toInt32(argMax(vehicle_per_day_deliveries, created_ts)) AS vehicle_per_day_deliveries
    FROM
        {{ source_db }}.{{ source_table_vehicle_productivity }}
    {% if log_dates is defined and log_dates %}
    WHERE log_date IN (SELECT log_date FROM log_dates_filter)
    {% endif %}
    GROUP BY
        log_date, fc_code, fc_name, vehicle_type
),
vehicle_productivity AS (
    SELECT
        log_date,
        fc_code,
        fc_name,
        SUM(no_of_vehicles) AS no_of_vehicles,
        SUM(vehicle_checkin_count) AS vehicle_checkin_count,
        (1-(vehicle_checkin_count/no_of_vehicles))*100 AS absent_rate,
        SUM(vehicle_per_day_deliveries) AS vehicle_per_day_deliveries
    FROM
        latest_vehicle_productivity
    GROUP BY
        log_date, fc_code, fc_name
),
resource_productivity AS (
    SELECT
        fc_code,
        month_year,
        category_id, 
        label_id,
        arrayElement(splitByChar('_', t.1), 1) AS resource_type,
        CASE WHEN t.1 = 'DCD' THEN 'DCD'
             WHEN t.1 = 'DPD' THEN 'DPD'
             WHEN t.1 = 'VEHICLES' THEN 'VEHICLES'
             ELSE arrayStringConcat(arraySlice(splitByChar('_', t.1), 2, 2), '_') END AS job_type,
        argMax(t.2, created_ts) AS value
    FROM {{ source_db }}.{{ source_table_resource_productivity_pc }}
    ARRAY JOIN [
        ('DA_FULL_TIME', da_full_time),
        ('DA_PART_TIME', da_part_time),
        ('SHOPPER_FULL_TIME', shoppers_full_time),
        ('SHOPPER_PART_TIME', shoppers_part_time),
        ('DCD', dcd),
        ('DPD', dpd),
        ('REFILLER_FULL_TIME', refiller_full_time),
        ('REFILLER_PART_TIME', refiller_part_time),
        ('LOADER_FULL_TIME', last_mile_loader_full_time),
        ('LOADER_PART_TIME', last_mile_loader_part_time),
        ('VEHICLES', vehicle)
    ] AS t
    GROUP BY
        fc_code, month_year, category_id, label_id, resource_type, job_type
    ),
resource_productivity_pi AS (
    SELECT
        fc_code,
        month_year,
        category_id,
        label_id,
        toInt32(argMax(da_full_time, created_ts)) AS da_full_time,
        toInt32(argMax(da_part_time, created_ts)) AS da_part_time,
        toInt32(argMax(shoppers_full_time, created_ts)) AS shoppers_full_time,
        toInt32(argMax(shoppers_part_time, created_ts)) AS shoppers_part_time,
        toInt32(argMax(refiller_full_time, created_ts)) AS refiller_full_time,
        toInt32(argMax(refiller_part_time, created_ts)) AS refiller_part_time,
        toInt32(argMax(last_mile_loader_full_time, created_ts)) AS last_mile_loader_full_time,
        toInt32(argMax(last_mile_loader_part_time, created_ts)) AS last_mile_loader_part_time,
        toInt32(argMax(vehicle, created_ts)) AS vehicle,
        toInt32(argMax(dcd, created_ts)) AS dcd,
        argMax(dpd, created_ts) AS dpd
    FROM
        {{ source_db }}.{{ source_table_resource_productivity_pc }}
    WHERE
        category_id = 3 AND label_id = 9
        {% if log_dates is defined and log_dates %}
        AND month_year IN (SELECT month_year FROM log_months_filter)
        {% endif %}
    GROUP BY
        fc_code, month_year, category_id, label_id
),
resource_productivity_hr AS (
    SELECT
        fc_code,
        month_year,
        argMax(da_full_time, created_ts) AS da_full_time,
        argMax(da_part_time, created_ts) AS da_part_time,
        argMax(shoppers_full_time, created_ts) AS shoppers_full_time,
        argMax(shoppers_part_time, created_ts) AS shoppers_part_time,
        argMax(refiller_full_time, created_ts) AS refiller_full_time,
        argMax(refiller_part_time, created_ts) AS refiller_part_time,
        argMax(last_mile_loader_full_time, created_ts) AS last_mile_loader_full_time,
        argMax(last_mile_loader_part_time, created_ts) AS last_mile_loader_part_time,
        argMax(vehicle, created_ts) AS vehicle,
        argMax(dcd, created_ts) AS dcd,
        argMax(dpd, created_ts) AS dpd
    FROM
        {{ source_db }}.{{ source_table_resource_productivity_pc }}
    WHERE
        category_id = 2 AND label_id = 6
        {% if log_dates is defined and log_dates %}
        AND month_year IN (SELECT month_year FROM log_months_filter)
        {% endif %}
    GROUP BY
        fc_code, month_year, category_id, label_id
),
resource_productivity_fc_1 AS (
    SELECT
        fc_code,
        month_year,
        argMax(da_full_time, created_ts) AS da_full_time,
        argMax(da_part_time, created_ts) AS da_part_time,
        argMax(shoppers_full_time, created_ts) AS shoppers_full_time,
        argMax(shoppers_part_time, created_ts) AS shoppers_part_time,
        argMax(refiller_full_time, created_ts) AS refiller_full_time,
        argMax(refiller_part_time, created_ts) AS refiller_part_time,
        argMax(last_mile_loader_full_time, created_ts) AS last_mile_loader_full_time,
        argMax(last_mile_loader_part_time, created_ts) AS last_mile_loader_part_time,
        argMax(vehicle, created_ts) AS vehicle,
        argMax(dcd, created_ts) AS dcd,
        argMax(dpd, created_ts) AS dpd
    FROM
        {{ source_db }}.{{ source_table_resource_productivity_pc }}
    WHERE
        category_id = 1 AND label_id = 2
        {% if log_dates is defined and log_dates %}
        AND month_year IN (SELECT month_year FROM log_months_filter)
        {% endif %}
    GROUP BY
        fc_code, month_year, category_id, label_id
),
resource_productivity_cal AS (
    SELECT
        fc_code,
        month_year,
        argMax(da_full_time, created_ts) AS da_full_time,
        argMax(da_part_time, created_ts) AS da_part_time,
        argMax(shoppers_full_time, created_ts) AS shoppers_full_time,
        argMax(shoppers_part_time, created_ts) AS shoppers_part_time,
        argMax(refiller_full_time, created_ts) AS refiller_full_time,
        argMax(refiller_part_time, created_ts) AS refiller_part_time,
        argMax(last_mile_loader_full_time, created_ts) AS last_mile_loader_full_time,
        argMax(last_mile_loader_part_time, created_ts) AS last_mile_loader_part_time,
        argMax(vehicle, created_ts) AS vehicle,
        argMax(dcd, created_ts) AS dcd,
        argMax(dpd, created_ts) AS dpd
    FROM
        {{ source_db }}.{{ source_table_resource_productivity_pc }}
    WHERE
        category_id = 4 AND label_id = 17
        {% if log_dates is defined and log_dates %}
        AND month_year IN (SELECT month_year FROM log_months_filter)
        {% endif %}
    GROUP BY
        fc_code, month_year, category_id, label_id
),
region AS (
    SELECT
        argMax(region, created_ts) AS region,
        argMax(state, created_ts) AS state,
        argMax(city, created_ts) AS city,
        fc_code
    FROM
        {{ source_db }}.{{ source_table_region }}
    GROUP BY
        fc_code
),
trends AS (
	SELECT
		a.log_date AS log_date,
        r.region AS region,
        r.state AS state,
        r.city AS city,
        fp.fc_code AS fc_code,
        fp.fc_name AS fc_name,
        UPPER(a.role) AS resource_type,
        a.job_type AS job_type,
        CASE WHEN resource_type = 'DA' AND job_type = 'FULL_TIME' THEN rp_hr.da_full_time 
	         WHEN resource_type = 'DA' AND job_type = 'PART_TIME' THEN rp_hr.da_part_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'FULL_TIME' THEN rp_hr.shoppers_full_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'PART_TIME' THEN rp_hr.shoppers_part_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'FULL_TIME' THEN rp_hr.refiller_full_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'PART_TIME' THEN rp_hr.refiller_part_time
	         WHEN resource_type = 'LOADER' AND job_type = 'FULL_TIME' THEN rp_hr.last_mile_loader_full_time
	         WHEN resource_type = 'LOADER' AND job_type = 'PART_TIME' THEN rp_hr.last_mile_loader_part_time
	         ELSE NULL END AS budgeted,
        CASE WHEN resource_type = 'DA' AND job_type = 'FULL_TIME' THEN rp_cal.da_full_time 
	         WHEN resource_type = 'DA' AND job_type = 'PART_TIME' THEN rp_cal.da_part_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'FULL_TIME' THEN rp_cal.shoppers_full_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'PART_TIME' THEN rp_cal.shoppers_part_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'FULL_TIME' THEN rp_cal.refiller_full_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'PART_TIME' THEN rp_cal.refiller_part_time
	         WHEN resource_type = 'LOADER' AND job_type = 'FULL_TIME' THEN rp_cal.last_mile_loader_full_time
	         WHEN resource_type = 'LOADER' AND job_type = 'PART_TIME' THEN rp_cal.last_mile_loader_part_time
	         ELSE NULL END AS over_budget,
        a.active AS active,
        a.present AS present,
        CASE WHEN resource_type = 'DA' AND job_type = 'FULL_TIME' THEN dp.distinct_full_time_das
	         WHEN resource_type = 'DA' AND job_type = 'PART_TIME' THEN dp.distinct_part_time_das
	         WHEN resource_type = 'SHOPPER' AND job_type = 'FULL_TIME' THEN sp.distinct_full_time_shoppers
	         WHEN resource_type = 'SHOPPER' AND job_type = 'PART_TIME' THEN sp.distinct_part_time_shoppers
	         WHEN resource_type = 'REFILLER' AND job_type = 'FULL_TIME' THEN a.present
	         WHEN resource_type = 'REFILLER' AND job_type = 'PART_TIME' THEN a.present
	         WHEN resource_type = 'LOADER' AND job_type = 'FULL_TIME' THEN a.present
	         WHEN resource_type = 'LOADER' AND job_type = 'PART_TIME' THEN a.present
	         ELSE NULL END AS utilized,
	    CASE WHEN present != 0 AND active != 0 THEN ROUND((1-(present/active)) * 100) ELSE NULL END AS absent_rate,
        CASE WHEN budgeted != 0 AND active != 0 THEN ROUND((1-(active/budgeted)) * 100) ELSE NULL END AS shortage_rate,
        CASE 
            WHEN resource_type = 'DA' AND job_type = 'FULL_TIME' THEN 
                COALESCE(ROUND(dp.hd_full_time_delivered_orders_count / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'DA' AND job_type = 'PART_TIME' THEN 
                COALESCE(ROUND(dp.hd_part_time_delivered_orders_count / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'SHOPPER' AND job_type = 'FULL_TIME' THEN 
                COALESCE(ROUND(sp.items_packed_count_full_time / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'SHOPPER' AND job_type = 'PART_TIME' THEN 
                COALESCE(ROUND(sp.items_packed_count_part_time / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'REFILLER' AND job_type = 'FULL_TIME' THEN 
                COALESCE(ROUND(fp.delivered_shipments_volume / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'REFILLER' AND job_type = 'PART_TIME' THEN 
                COALESCE(ROUND(fp.delivered_shipments_volume / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'LOADER' AND job_type = 'FULL_TIME' THEN
                COALESCE(ROUND(fp.delivered_shipments_volume / NULLIF(utilized, 0)), 0)
            WHEN resource_type = 'LOADER' AND job_type = 'PART_TIME' THEN
                COALESCE(ROUND(fp.delivered_shipments_volume / NULLIF(utilized, 0)), 0)
            ELSE 0
        END AS productivity_actual,
        CASE WHEN resource_type = 'DA' AND job_type = 'FULL_TIME' THEN rp_fc_1.da_full_time 
	         WHEN resource_type = 'DA' AND job_type = 'PART_TIME' THEN rp_fc_1.da_part_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'FULL_TIME' THEN rp_fc_1.shoppers_full_time
	         WHEN resource_type = 'SHOPPER' AND job_type = 'PART_TIME' THEN rp_fc_1.shoppers_part_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'FULL_TIME' THEN rp_fc_1.refiller_full_time
	         WHEN resource_type = 'REFILLER' AND job_type = 'PART_TIME' THEN rp_fc_1.refiller_part_time
	         WHEN resource_type = 'LOADER' AND job_type = 'FULL_TIME' THEN rp_fc_1.last_mile_loader_full_time
	         WHEN resource_type = 'LOADER' AND job_type = 'PART_TIME' THEN rp_fc_1.last_mile_loader_part_time
	         ELSE NULL END AS productivity_goal
    FROM
        attendance a
    LEFT JOIN region r
    ON a.fc_code = r.fc_code
 	LEFT JOIN fc_productivity fp
    ON fp.fc_code = a.fc_code AND fp.log_date = a.log_date
    LEFT JOIN shopper_productivity sp
    ON a.fc_code = sp.fc_code AND a.log_date = sp.log_date
    LEFT JOIN da_productivity dp
    ON a.fc_code = dp.fc_code AND a.log_date = dp.log_date
    LEFT JOIN resource_productivity_hr rp_hr
    ON a.fc_code = rp_hr.fc_code AND toStartOfMonth(a.log_date) = toDate(rp_hr.month_year)
    LEFT JOIN resource_productivity_fc_1 rp_fc_1
    ON a.fc_code = rp_fc_1.fc_code AND toStartOfMonth(a.log_date) = toDate(rp_fc_1.month_year)
    LEFT JOIN resource_productivity_cal rp_cal
    ON a.fc_code = rp_cal.fc_code AND toStartOfMonth(a.log_date) = toDate(rp_cal.month_year)
    UNION ALL
    SELECT
    	dp.log_date AS log_date,
        r.region AS region,
        r.state AS state,
        r.city AS city,
        dp.fc_code AS fc_code,
        dp.fc_name AS fc_name,
        'DCD' AS resource_type,
        'DCD' AS job_type,
        rp_hr.dcd AS budgeted,
        rp_cal.dcd AS over_budget,
        rp_pi.dcd AS active,
        dp.distinct_dcd AS present,
        dp.distinct_dcd AS utilized,
	    CASE WHEN present != 0 AND active != 0 THEN ROUND((1-(present/active)) * 100) ELSE NULL END AS absent_rate,
        CASE WHEN budgeted != 0 AND active != 0 THEN ROUND((1-(active/budgeted)) * 100) ELSE NULL END AS shortage_rate,
        CASE WHEN utilized != 0 THEN ROUND(dp.hd_dcd_delivered_orders_count/utilized) ELSE NULL END AS productivity_actual,
        rp_fc_1.dcd AS productivity_goal
    FROM
        da_productivity dp
    LEFT JOIN region r
    ON dp.fc_code = r.fc_code
    LEFT JOIN resource_productivity_hr rp_hr
    ON dp.fc_code = rp_hr.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_hr.month_year)
    LEFT JOIN resource_productivity_fc_1 rp_fc_1
    ON dp.fc_code = rp_fc_1.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_fc_1.month_year)
    LEFT JOIN resource_productivity_cal rp_cal
    ON dp.fc_code = rp_cal.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_cal.month_year)
    LEFT JOIN resource_productivity_pi rp_pi
    ON dp.fc_code = rp_pi.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_pi.month_year)
    UNION ALL
    SELECT
    	dp.log_date AS log_date,
        r.region AS region,
        r.state AS state,
        r.city AS city,
        dp.fc_code AS fc_code,
        dp.fc_name AS fc_name,
        'DPD' AS resource_type,
        'DPD' AS job_type,
        rp_hr.dpd AS budgeted,
        rp_cal.dpd AS over_budget,
        rp_pi.dpd AS active,
        dp.distinct_dpd AS present,
        dp.distinct_dpd AS utilized,
	    CASE WHEN present != 0 AND active != 0 THEN ROUND((1-(present/active)) * 100) ELSE NULL END AS absent_rate,
        CASE WHEN budgeted != 0 AND active != 0 THEN ROUND((1-(active/budgeted)) * 100) ELSE NULL END AS shortage_rate,
        CASE WHEN utilized != 0 THEN ROUND(dp.hd_dpd_delivered_orders_count/utilized) ELSE NULL END AS productivity_actual,
        rp_fc_1.dpd AS productivity_goal
    FROM
        da_productivity dp
    LEFT JOIN region r
    ON dp.fc_code = r.fc_code
    LEFT JOIN resource_productivity_hr rp_hr
    ON dp.fc_code = rp_hr.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_hr.month_year)
    LEFT JOIN resource_productivity_fc_1 rp_fc_1
    ON dp.fc_code = rp_fc_1.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_fc_1.month_year)
    LEFT JOIN resource_productivity_cal rp_cal
    ON dp.fc_code = rp_cal.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_cal.month_year)
    LEFT JOIN resource_productivity_pi rp_pi
    ON dp.fc_code = rp_pi.fc_code AND toStartOfMonth(dp.log_date) = toDate(rp_pi.month_year)
    UNION ALL
    SELECT
    	vp.log_date AS log_date,
        r.region AS region,
        r.state AS state,
        r.city AS city,
        vp.fc_code AS fc_code,
        vp.fc_name AS fc_name,
        'VEHICLES' AS resource_type,
        'VEHICLES' AS job_type,
        rp_hr.vehicle AS budgeted,
        rp_cal.vehicle AS over_budget,
        rp_hr.vehicle AS active,
        vp.vehicle_checkin_count AS present,
        vp.no_of_vehicles AS utilized,
	    CASE WHEN present != 0 AND active != 0 THEN ROUND((1-(present/active)) * 100) ELSE NULL END AS absent_rate,
        CASE WHEN budgeted != 0 AND active != 0 THEN ROUND((1-(active/budgeted)) * 100) ELSE NULL END AS shortage_rate,
        CASE WHEN utilized != 0 THEN ROUND(vp.vehicle_per_day_deliveries/utilized) ELSE NULL END AS productivity_actual,
        rp_fc_1.vehicle AS productivity_goal
    FROM
        vehicle_productivity vp
    LEFT JOIN region r
    ON vp.fc_code = r.fc_code
    LEFT JOIN resource_productivity_hr rp_hr
    ON vp.fc_code = rp_hr.fc_code AND toStartOfMonth(vp.log_date) = toDate(rp_hr.month_year)
    LEFT JOIN resource_productivity_fc_1 rp_fc_1
    ON vp.fc_code = rp_fc_1.fc_code AND toStartOfMonth(vp.log_date) = toDate(rp_fc_1.month_year)
    LEFT JOIN resource_productivity_cal rp_cal
    ON vp.fc_code = rp_cal.fc_code AND toStartOfMonth(vp.log_date) = toDate(rp_cal.month_year)
)
SELECT DISTINCT * FROM trends;
