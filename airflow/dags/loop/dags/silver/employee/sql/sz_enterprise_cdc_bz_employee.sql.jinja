{% set use_cluster = env in ['uat', 'prod'] %}

CREATE MATERIALIZED VIEW {{ target_db }}.{{ target_view }}
{% if use_cluster %}
ON CLUSTER {{ target_cluster }}
{% endif %}
TO {{ target_db }}.{{ target_table }}
(
    `batch_id` Nullable(String),
    `event_date` String,
    `employee_id` String,
    `created_by` String,
    `created_ts` DateTime,
    `updated_by` String,
    `updated_ts` DateTime,
    `enterprise_id` String,
    `ramco_id` Nullable(String),
    `joining_date` Nullable(Date),
    `full_name` Nullable(String),
    `dob` Nullable(Date),
    `gender` Nullable(String),
    `fc_code` Nullable(String),
    `city` Nullable(String),
    `state` Nullable(String),
    `old_employee_id` Nullable(String),
    `sub_loc` Nullable(String),
    `job_type` Nullable(String),
    `role` Nullable(String),
    `last_working_date` Nullable(Date),
    `is_active` UInt8,
    `vendor` Nullable(String),
    `is_temporary_user` Int16,
    `loginid` Nullable(String),
    `email` Nullable(String),
    `enterprise_fc_code` Nullable(String),
    `enterprise_role` Nullable(String),
    `is_manually_created` UInt8
)
AS
WITH employee AS (
    SELECT
        employee_id,
        nullIf(argMax(batch_id, event_date), '') AS batch_id,
        argMax(created_by, event_date) AS created_by,
        argMax(created_ts, event_date) AS created_ts,
        argMax(updated_by, event_date) AS updated_by,
        argMax(joining_date, event_date) AS joining_date,
        argMax(full_name, event_date) AS full_name,
        argMax(role, event_date) AS role,
        argMax(job_type, event_date) AS job_type,
        argMax(dob, event_date) AS dob,
        argMax(gender, event_date) AS gender,
        argMax(fc_code, event_date) AS fc_code,
        argMax(city, event_date) AS city,
        argMax(state, event_date) AS state,
        argMax(old_employee_id, event_date) AS old_employee_id,
        argMax(sub_loc, event_date) AS sub_loc,
        argMax(last_working_date, event_date) AS last_working_date,
        argMax(is_active, event_date) AS is_active,
        argMax(vendor, event_date) AS vendor,
        argMax(enterprise_role, event_date) AS enterprise_role,
        argMax(is_temporary_user, event_date) AS is_temporary_user,
        argMax(is_manually_created, event_date) AS is_manually_created,
        argMax(enterprise_fc_code, event_date) AS enterprise_fc_code,
        argMax(ramco_id, event_date) AS ramco_id,
        argMax(email, event_date) AS email,
        argMax(loginid, event_date) AS loginid
    FROM {{ target_db }}.{{ target_table }}
    GROUP BY employee_id
),
enterprise_employee AS (
    SELECT
        JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeecode',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value') AS employeecode,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeejoiningdate',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeejoiningdate,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'firstname',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS firstname,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'lastname',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS lastname,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeedateofbirth',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeedateofbirth,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeegender',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeegender,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'fccode',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS fccode,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeejobtype',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeejobtype,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeecity',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeecity,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeestate',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeestate,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'deactivationdate',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS deactivationdate,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'istemporaryuser',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS istemporaryuser,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'loginid',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS loginid,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeerole',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeerole,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeevendor',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeevendor,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeestatus',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeestatus,
        nullIf(JSONExtractString(arrayFilter(x -> JSONExtractString(x,'name') = 'employeeemail',
            JSONExtractArrayRaw(JSONExtractArrayRaw(rows)[1],'cells'))[1],'value'),'') AS employeeemail,
        triggerdate
    FROM {{ source_db }}.{{ source_enterprise_employee_table }}
)
SELECT
    coalesce(s.batch_id,NULL) AS batch_id,
    b.triggerdate AS event_date,
    b.employeecode AS employee_id,
    coalesce(nullIf(s.created_by,''),'enterprise_cdc') AS created_by,
    coalesce(s.created_ts,now()) AS created_ts,
    'enterprise_cdc' AS updated_by,
    now() AS updated_ts,
    coalesce(nullIf(s.employee_id,''),b.employeecode) AS enterprise_id,
    multiIf(is_manually_created = 1,NULL,coalesce(nullIf(s.ramco_id,''),b.employeecode)) AS ramco_id,
    coalesce(nullIf(s.joining_date,'1970-01-01'),
        toDate(parseDateTimeBestEffortOrNull(b.employeejoiningdate))) AS joining_date,
    multiIf(b.lastname IS NULL,
        coalesce(nullIf(s.full_name,''),b.firstname),
        coalesce(nullIf(s.full_name,''),concat(toString(firstname),' ',toString(lastname)))) AS full_name,
    coalesce(nullIf(s.dob,'1970-01-01'),
        toDate(parseDateTimeBestEffortOrNull(b.employeedateofbirth))) AS dob,
    coalesce(nullIf(s.gender,''),b.employeegender) AS gender,
    coalesce(nullIf(s.fc_code,''),b.fccode) AS fc_code,
    coalesce(nullIf(s.city,''),b.employeecity) AS city,
    coalesce(nullIf(s.state,''),b.employeestate) AS state,
    coalesce(nullIf(s.old_employee_id,''),NULL) AS old_employee_id,
    coalesce(nullIf(s.sub_loc,''),NULL) AS sub_loc,
    coalesce(nullIf(s.job_type,''),b.employeejobtype) AS job_type,
    coalesce(nullIf(s.role,''),b.employeerole) AS role,
    coalesce(nullIf(s.last_working_date,'1970-01-01'),
        toDate(parseDateTimeBestEffortOrNull(b.deactivationdate))) AS last_working_date,
    if(b.employeestatus = 'true',1,0) AS is_active,
    coalesce(nullIf(s.vendor,''),b.employeevendor) AS vendor,
    coalesce(nullIf(s.is_temporary_user,NULL),
        if(b.istemporaryuser = 'Y',1,0)) AS is_temporary_user,
    coalesce(nullIf(s.loginid,''),b.loginid) AS loginid,
    coalesce(nullIf(s.email,''),b.employeeemail) AS email,
    coalesce(nullIf(s.enterprise_fc_code,''),b.fccode) AS enterprise_fc_code,
    coalesce(nullIf(s.enterprise_role,''),b.employeerole) AS enterprise_role,
    if(match(employee_id,'^M'),1,0) AS is_manually_created
FROM enterprise_employee AS b
LEFT JOIN employee AS s ON b.employeecode = s.employee_id;